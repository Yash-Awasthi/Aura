<?xml version="1.0" encoding="utf-8"?>
<!-- Task 87 — FIDO2 provider settings layout -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarFidoSettings"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:title="AURA as Password Provider"
        app:navigationIcon="@drawable/ic_back"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Passkey list -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enrolled Passkeys"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPasskeys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Hardware key relay section (enterprise only) -->
            <LinearLayout
                android:id="@+id/sectionHwKeyRelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:visibility="gone">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hardware Key Relay"
                    android:textAppearance="?attr/textAppearanceTitleMedium" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AURA relays CTAP2 requests to a paired hardware security key via NFC."
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:paddingTop="4dp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHwRelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable hardware key relay"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
